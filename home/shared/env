#!/usr/bin/env bash

_brew_cache="$HOME/.cache/brew_shellenv.sh"
if [[ -x /opt/homebrew/bin/brew ]]; then
  _brew_bin=/opt/homebrew/bin/brew
elif [[ -x /usr/local/bin/brew ]]; then
  _brew_bin=/usr/local/bin/brew
fi
if [[ -n "$_brew_bin" ]]; then
  if [[ ! -f "$_brew_cache" ]] || [[ "$_brew_bin" -nt "$_brew_cache" ]]; then
    "$_brew_bin" shellenv >"$_brew_cache" 2>/dev/null
  fi
  . "$_brew_cache"
fi
unset _brew_bin _brew_cache

export EDITOR='nvim'
export FZF_ALT_C_OPTS="--preview='tree -L 1 {}'"
export FZF_CTRL_T_COMMAND="fd --type file --follow --hidden --exclude .git"
export FZF_CTRL_T_OPTS="--preview 'bat --style=numbers --color=always --line-range :500 {}' --bind 'enter:execute(tmux send-keys \"C-c\" \"Enter\" \"$EDITOR {+}\" \"Enter\")+abort' --multi"
export FZF_DEFAULT_COMMAND="rg --files --hidden"
export FZF_TMUX_OPTS='-p 80%,60%'
export BUN_INSTALL="$HOME/.bun"

[[ -d "$HOME/.local/bin" ]] && PATH="$HOME/.local/bin:$PATH"
[[ -d "$HOME/.local/share/nvim/mason/bin" ]] && PATH="$HOME/.local/share/nvim/mason/bin:$PATH"
[[ -d "$HOME/go/bin" ]] && PATH="$HOME/go/bin:$PATH"
[[ -d "$HOME/.cargo/bin" ]] && PATH="$HOME/.cargo/bin:$PATH"
[[ -d "$HOME/.opencode/bin" ]] && PATH="$HOME/.opencode/bin:$PATH"
[[ -d $BUN_INSTALL ]] && PATH="$BUN_INSTALL/bin:$PATH"
[[ -d "$HOME/.gem/ruby/4.0.0/bin" ]] && PATH="$HOME/.gem/ruby/4.0.0/bin:$PATH"

export PATH

if [[ -z "$XDG_CONFIG_HOME" ]]; then
  export XDG_CONFIG_HOME="$HOME/.config"
fi

if command -v vivid &>/dev/null; then
  _vivid_cache="$HOME/.cache/vivid_ls_colors"
  if [[ ! -f "$_vivid_cache" ]] || [[ "$(command -v vivid)" -nt "$_vivid_cache" ]]; then
    vivid generate molokai >"$_vivid_cache" 2>/dev/null
  fi
  export LS_COLORS="$(<"$_vivid_cache")"
  unset _vivid_cache
fi
