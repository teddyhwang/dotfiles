#!/usr/bin/env bash

[[ -n "$_shared_init_loaded" ]] && return
_shared_init_loaded=1

if [[ -n "$ZSH_VERSION" ]]; then
  _shared_init_cache="$HOME/.cache/shared_init_cache.zsh"
else
  _shared_init_cache="$HOME/.cache/shared_init_cache.bash"
fi
_shared_init_regen=0

if [[ ! -f "$_shared_init_cache" ]]; then
  _shared_init_regen=1
elif [[ -n "$ZSH_VERSION" ]]; then
  eval '_stale=( $_shared_init_cache(N.mh+24) )'
  ((${#_stale})) && _shared_init_regen=1
  unset _stale
elif [[ -n "$BASH_VERSION" ]] && [[ $(find "$_shared_init_cache" -mmin +1440 2>/dev/null) ]]; then
  _shared_init_regen=1
fi

_shared_init_regen_cache() {
  local _cache="$1" _shell="$2"
  local _tmp="${_cache}.tmp.$$"
  : >"$_tmp"

  if command -v gh &>/dev/null; then
    gh completion -s "$_shell" >>"$_tmp" 2>/dev/null
  fi
  if command -v zoxide &>/dev/null; then
    zoxide init "$_shell" >>"$_tmp" 2>/dev/null
  fi
  if [[ "$_shell" == "zsh" ]]; then
    command -v gt &>/dev/null && gt completion >>"$_tmp" 2>/dev/null
    command -v carapace &>/dev/null && carapace _carapace >>"$_tmp" 2>/dev/null
  fi
  if command -v tv &>/dev/null; then
    tv init "$_shell" >>"$_tmp" 2>/dev/null
  fi
  if command -v atuin &>/dev/null; then
    atuin init "$_shell" --disable-up-arrow >>"$_tmp" 2>/dev/null
  fi
  if command -v shadowenv &>/dev/null; then
    "$(which shadowenv)" init "$_shell" >>"$_tmp" 2>/dev/null
  fi
  if command -v try &>/dev/null; then
    command try init >>"$_tmp" 2>/dev/null
  fi

  mv -f "$_tmp" "$_cache"
}

if [[ "$_shared_init_regen" == "1" ]]; then
  mkdir -p "$HOME/.cache"
  local _shell
  [[ -n "$ZSH_VERSION" ]] && _shell=zsh || _shell=bash

  if [[ -f "$_shared_init_cache" ]]; then
    # Stale cache exists — use it now, regen in background for next shell
    source "$_shared_init_cache"
    _shared_init_regen_cache "$_shared_init_cache" "$_shell" &!
  else
    # No cache at all — must regen synchronously
    _shared_init_regen_cache "$_shared_init_cache" "$_shell"
    source "$_shared_init_cache"
  fi
  unset _shell
else
  source "$_shared_init_cache"
fi
unset _shared_init_cache _shared_init_regen

[ -n "$ZSH_VERSION" ] && [ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
